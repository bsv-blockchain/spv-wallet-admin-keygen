# ================================================================================================
# 🏗️ PROJECT-SPECIFIC CONFIGURATION (90-project.env)
# ================================================================================================
#
# Purpose: Project-specific overrides for spv-wallet-admin-keygen
# Load Order: 90 (loaded last before 99-local.env, overrides all defaults)
#
# This file contains project-specific settings that differ from the defaults
# defined in the lower-numbered configuration files (00-core, 10-*, 20-*).
#
# ================================================================================================

# ================================================================================================
# 📊 COVERAGE PROVIDER
# ================================================================================================

# Use Codecov as the coverage provider (overrides default: internal)
GO_COVERAGE_PROVIDER=codecov

# Codecov Configuration (overrides default: false)
CODECOV_TOKEN_REQUIRED=true

# ================================================================================================
# 🚫 COVERAGE EXCLUSIONS
# ================================================================================================
# Matches the ignore paths defined in codecov.yml

GO_COVERAGE_EXCLUDE_PATHS=.github/,.mage-cache/,.vscode/,bin/,example/,examples/,mocks/,testing/,test/,vendor/,testdata/
